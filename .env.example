# Copie este arquivo para .env e preencha com suas credenciais reais.
PARADISE_API_KEY=sk_sua_chave_secreta_aqui
PARADISE_BASE_URL=https://multi.paradisepags.com/api/v1
PUBLIC_BASE_URL=https://www.seudominio.com.br
PARADISE_WEBHOOK_TOKEN=CRIE_UM_TOKEN_ALEATORIO_E_SECRETO

# Alertas no app ntfy. Escolha um topico longo e privado.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=enifler-alertas-troque-por-um-nome-secreto
# Opcional, mas recomendado se o seu servidor ntfy exigir autenticacao.
NTFY_ACCESS_TOKEN=
ENIFLER_PORT=4173
ENIFLER_COOKIE_SECRET=GERAR_UMA_CHAVE_GRANDE_ALEATORIA_AQUI

# Banco real usado pelo login, cadastro, pedidos e produtos.
ENIFLER_DB_DRIVER=supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# Opcional: chave pública, se depois quiser usar recursos públicos do Supabase no frontend.
SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# O admin fica cadastrado na tabela public.admin_users do Supabase.
